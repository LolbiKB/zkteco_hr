{
  "app": "zkteco_hr",
  "app_src": "../..",
  "required_apps": ["erpnext", "hrms"],
  "branch": "version-15",
  "frontend_dir": "../../zkteco_hr/zkteco_hr/frontend/hr_attendance",
  "register_app_in_apps_txt": true,
  "exercise": {
    "method": "zkteco_hr.attendance_engine.dev_tools.run_engine_for_employee",
